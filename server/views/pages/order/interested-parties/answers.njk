 {% from "govuk/components/details/macro.njk" import govukDetails %}

 <h2 class="govuk-heading-m">Organisation details</h2>

{{ govukSummaryList({
  classes: "govuk-!-margin-bottom-9",
  rows: interestedParties
}) }}

{% if not containsResponsibleOrgDetails %}
  {% call govukDetails({
    summaryText: "How do I change the Responsible Officer or Responsible Organisation?"
  }) %}
    Use the service request portal if you have access. If you don't have access, download and complete the <a href="./documents/post-release-orders-NAT-probation-practitioner-notification-form-to-EMS.doc" class="govuk-link" download>Post release orders - NAT Probation Practitioner Notification Form to EMS</a> and email it to EMSEnforcement@ems.co.uk.
  {% endcall %}
{% endif%}

{% if probationDeliveryUnit | length > 0%}
  <h2 class="govuk-heading-m">Probation delivery unit</h2>

  {{ govukSummaryList({
    classes: "govuk-!-margin-bottom-9",
    rows: probationDeliveryUnit
  }) }}
{% endif%}
