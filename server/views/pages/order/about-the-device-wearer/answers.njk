  <h2 class="govuk-heading-m">Personal details</h2>

  {{ govukSummaryList({
    classes: "govuk-!-margin-bottom-9",
    rows: deviceWearer
  }) }}

  <h2 class="govuk-heading-m">Identity numbers</h2>


  {{ govukSummaryList({
    classes: "govuk-!-margin-bottom-9",
    rows: personIdentifiers
  }) }}

  {% if responsibleAdult | length > 0 %}

   <h2 class="govuk-heading-m">Responsible adult details</h2>

    {{ govukSummaryList({
      classes: "govuk-!-margin-bottom-9",
      rows: responsibleAdult
    }) }}


  {% endif %}
  {% if contactDetails | length > 0 %}
   <h2 class="govuk-heading-m">Telephone number</h2>

  {{ govukSummaryList({
    classes: "govuk-!-margin-bottom-9",
    rows: contactDetails
  }) }}
  {% endif %}
    {% if addresses | length > 0 %}
   <h2 class="govuk-heading-m">Device wearer's addresses</h2>

  {{ govukSummaryList({
    classes: "govuk-!-margin-bottom-9",
    rows: addresses
  }) }}
    {% endif %}