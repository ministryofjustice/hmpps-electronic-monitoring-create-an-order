{% extends "../../../partials/layout.njk" %}

{% set pageTitle = applicationName + " - Form Details" %}
{% set mainClasses = "app-container govuk-body" %}
{% from "moj/components/page-header-actions/macro.njk" import mojPageHeaderActions %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/fieldset/macro.njk" import govukFieldset %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}

  {{ govukBackLink({
    text: "Back",
    href: orderSummaryUri
  }) }}

  {% if not isOrderEditable %}
      {% set html %}
        <p class="govuk-notification-banner__heading">
          You are viewing a submitted order.
        </p>
      {% endset %}

      {{ govukNotificationBanner({
        html: html
      }) }}
  {% endif %}

  <div class="homepage-content">
    {{ mojPageHeaderActions({
      heading: {
          text: "Contact information"
      }
    }) }}
  </div>

  <form action="" method="post">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <input type="hidden" name="addressType" value="{{ addressType.value }}">

    {% call govukFieldset({
      legend: {
        text: addressType.value | capitalize + " address",
        classes: "govuk-fieldset__legend--l",
        isPageHeading: false
      }
    }) %}

      {{ govukRadios({
        name: "hasFixedAddress",
        classes: "govuk-radios--inline",
        fieldset: {
          legend: {
            text: "Does the device wearer have a fixed address?",
            isPageHeading: false,
            classes: "govuk-fieldset__legend--s"
          }
        },
        hint: {
          text: "For example, the device wearer has a tenancy or permanent address they are registed at"
        },
        items: [
          {
            value: "true",
            text: "Yes, they have a fixed address",
            disabled: not isOrderEditable
          },
          {
            value: "false",
            text: "No, they have no fixed abode",
            disabled: not isOrderEditable
          }
        ],
        value: hasFixedAddress.value,
        errorMessage: hasFixedAddress.error,
        disabled: not isOrderEditable
      }) }}

      <div class="govuk-!-width-two-thirds">
        <h4 class="govuk-heading-s">What is the device wearer's primary address?</h4>
        <p>
          If the device wearer has multiple addresses, enter the address where they spend most of their time or have registered as their home residence
        </p>
      </div>

      {{ govukInput({
        label: {
          text: "Addresss line 1"
        },
        classes: "govuk-!-width-two-thirds",
        id: "address-line-1",
        name: "addressLine1",
        value: addressLine1.value,
        errorMessage: addressLine1.error,
        disabled: not isOrderEditable
      }) }}

      {{ govukInput({
        label: {
          text: "Addresss line 2"
        },
        classes: "govuk-!-width-two-thirds",
        id: "address-line-2",
        name: "addressLine2",
        value: addressLine2.value,
        errorMessage: addressLine2.error,
        disabled: not isOrderEditable
      }) }}

      {{ govukInput({
        label: {
          text: "Addresss line 3"
        },
        classes: "govuk-!-width-two-thirds",
        id: "address-line-3",
        name: "addressLine3",
        value: addressLine3.value,
        errorMessage: addressLine3.error,
        disabled: not isOrderEditable
      }) }}

      {{ govukInput({
        label: {
          text: "Addresss line 4"
        },
        classes: "govuk-!-width-two-thirds",
        id: "address-line-4",
        name: "addressLine4",
        value: addressLine4.value,
        errorMessage: addressLine4.error,
        disabled: not isOrderEditable
      }) }}

      {{ govukInput({
        label: {
          text: "Postcode"
        },
        classes: "govuk-!-width-two-thirds",
        id: "postcode",
        name: "postcode",
        value: postcode.value,
        errorMessage: postcode.error,
        disabled: not isOrderEditable
      }) }}

      {{ govukRadios({
        name: "hasAnotherAddress",
        classes: "govuk-radios--inline",
        fieldset: {
          legend: {
            text: "Does the device wearer have another address they will be monitored at?",
            isPageHeading: false,
            classes: "govuk-fieldset__legend--s"
          }
        },
        hint: {
          text: "For example, the device wearer will spend curfew hours at another address. Examples of second addresses include living part time in another address due to separated parents or living on-site at a school or university during term time.",
          classes: "govuk-!-width-two-thirds"
        },
        items: [
          {
            value: "true",
            text: "Yes",
            disabled: not isOrderEditable
          },
          {
            value: "false",
            text: "No",
            disabled: not isOrderEditable
          }
        ],
        value: hasAnotherAddress.value,
        errorMessage: hasAnotherAddress.error,
        disabled: not isOrderEditable
      }) }}

    {% endcall %}

    <div class="govuk-button-group">
      {% if isOrderEditable %}
        {{ govukButton({
            text: "Save and continue",
            name: "action",
            value: "continue"
        }) }}
        {{ govukButton({
            text: "Save and return back to to form section menu",
            classes: "govuk-button--secondary",
            name: "action",
            value: "back"
        }) }}
      {% else %}
        <a id="backToSummary" class="govuk-link" href="{{ orderSummaryUri }}">Return back to to form section menu</a>
      {% endif %}
    </div>
  </form>

{% endblock %}
