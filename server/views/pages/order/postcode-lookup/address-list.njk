{% extends "../../../partials/form-layout.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set section = content.pages.addressList.section %}
{% set heading = content.pages.addressList.title %}
{% set questions = content.pages.addressList.questions %}

{% block formInputs %}

  {{ govukSummaryList({
      rows: items,
      classes: "govuk-!-margin-bottom-9"
  }) }}

  {% if showAddAnother %}
    {{ govukRadios({
      name: "addAnother",
      classes: "govuk-radios--inline",
      fieldset: {
        legend: {
          text: questions.addAnother.text,
          isPageHeading: false,
          classes: "govuk-fieldset__legend--s"
        }
      },
      items: [
        {
          value: "true",
          text: "Yes",
          disabled: not isOrderEditable
        },
        {
          value: "false",
          text: "No",
          disabled: not isOrderEditable
        }
      ],
      errorMessage: addAnother.error
    }) }}
  {% endif %}
{% endblock %}
