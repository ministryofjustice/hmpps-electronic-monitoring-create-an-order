{% extends "../../../partials/form-layout.njk" %}

{% from "govuk/components/radios/macro.njk" import govukRadios %}

{% set section = content.section %}
{% set heading = 'No results found' %}
{% set questions = content.questions %}

{% if buildingId %}
  {% set hint = 'We could not find an address that matches <b>' + postcode + '</b> and <b>' + buildingId + '</b>. You can search again or enter the address manually.' %}
{% else %}
  {% set hint = 'We could not find an address that matches <b>' + postcode + '</b>. You can search again or enter the address manually.' %}
{% endif %}

{% set searchText = '<a href="' + searchAgainLink + '" class="govuk-link">Search again</a>' %}


{% block formInputs %}
    <p class="govuk-body">{{ hint | safe }}</p>

    <p class="govuk-body">
      <a href="{{ searchAgainLink }}" class="govuk-link">Search again</a>
    </p>

    <p class="govuk-body">
      <a href="{{ manualAddressLink }}" class="govuk-link">Enter address manually</a>
    </p>
{% endblock %}
